{
    "name": "hxtp-micro",
    "version": "1.0.3",
    "description": "HXTP/3.0 protocol SDK for ESP32 and ESP8266 IoT devices. Production-grade HMAC-SHA256 signing, 7-step validation pipeline, binary framing, capability registry, and MQTT transport. Zero dynamic allocation in hot path.",
    "keywords": [
        "hxtp",
        "iot",
        "mqtt",
        "esp32",
        "esp8266",
        "protocol",
        "hmac",
        "embedded",
        "arduino",
        "tls"
    ],
    "license": "MIT",
    "homepage": "https://github.com/hestialabs/hxtp-micro",
    "authors": [
        {
            "name": "Hestia Labs LLP",
            "url": "https://github.com/hestialabs"
        }
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/hestialabs/hxtp-micro.git"
    },
    "frameworks": "arduino",
    "platforms": [
        "espressif32",
        "espressif8266"
    ],
    "headers": [
        "Hxtp.h",
        "hxtp-micro.h"
    ],
    "dependencies": {
        "knolleary/PubSubClient": "^2.8"
    },
    "build": {
        "flags": [
            "-std=gnu++17",
            "-fno-exceptions",
            "-fno-rtti"
        ]
    },
    "export": {
        "exclude": [
            "examples/*"
        ]
    },
    "examples": [
        "examples/BasicDevice/BasicDevice.ino",
        "examples/BuildTest/BuildTest.ino",
        "examples/MultiCapabilityDevice/MultiCapabilityDevice.ino",
        "examples/SmartRelay/SmartRelay.ino",
        "examples/TelemetryDevice/TelemetryDevice.ino"
    ]
}